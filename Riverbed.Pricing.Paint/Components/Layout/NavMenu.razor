@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using DevExpress.Blazor
@using Riverbed.Pricing.Paint.Shared.Data
@using Riverbed.Pricing.Paint.Shared.Services
@implements IDisposable
@inject NavigationManager NavigationManager
@inject ThemeService ThemeService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@rendermode InteractiveServer

<style>
    /* TreeView text adapts to current theme */
    .dxbl-treeview .dxbl-text { color: var(--bs-body-color); }
    /* Ensure default expander chevron is visible */
    .dxbl-treeview .dxbl-treeview-expander-icon svg {
        filter: none;
        color: var(--bs-body-color);
    }
    /* Sidebar sections */
    .logout-section {
        padding: 0.5rem;
        border-top: 1px solid var(--bs-border-color);
        background-color: var(--bs-tertiary-bg);
    }
    .logout-button {
        background: none;
        border: none;
        padding: 0.5rem;
        margin: 0;
        color: var(--bs-body-color);
        text-align: left;
        width: 100%;
        font-family: inherit;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        border-radius: 4px;
    }
    .logout-button:hover {
        background-color: var(--bs-secondary-bg);
        text-decoration: none;
    }
</style>

<div class="d-flex flex-column h-100">
    <!-- Brand header -->
    <div class="navbar px-3" style="min-height:48px; background-color: var(--bs-secondary-bg); border-bottom: 1px solid var(--bs-border-color); color: var(--bs-body-color);">
        <span class="navbar-brand m-0" style="color: var(--bs-body-color);">QUOTED</span>
    </div>

    <!-- Menu content -->
    <div class="p-2" style="background-color: var(--bs-tertiary-bg); border-right: 1px solid var(--bs-border-color); flex-grow: 1; overflow-y: auto;">
        <DxTreeView AllowSelectNodes="true" AnimationType="LayoutAnimationType.Slide">
            <Nodes>
                <DxTreeViewNode Text="Home" NavigateUrl="dashboard" />
                <DxTreeViewNode Text="Menu" Expand="true">
                    <Nodes>
                        <DxTreeViewNode Text="Dashboard" NavigateUrl="dashboard" />
                        <DxTreeViewNode Text="Customers" NavigateUrl="company-customer-list" />
                        <DxTreeViewNode Text="Projects" NavigateUrl="project/quoted-projects" />
                        <DxTreeViewNode Text="Project Board" NavigateUrl="customer-projects-board" />
                    </Nodes>
                </DxTreeViewNode>
                <AuthorizeView>
                    <Authorized>
                        <DxTreeViewNode Text="Company" Expand="true">
                            <Nodes>
                                <DxTreeViewNode Text="Company Settings" NavigateUrl="companysettings" />  
                                <DxTreeViewNode Text="Reports Editor" NavigateUrl="company-html-report-edit-host" /> 								
                                <DxTreeViewNode Text="Kiosk Wizard" NavigateUrl="kiosk-wizard" />
                                <DxTreeViewNode Text="Painting Wizard" NavigateUrl="painting-wizard" />
                            </Nodes>
                        </DxTreeViewNode>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Roles="Administrator">
                    <Authorized>
                        <DxTreeViewNode Text="Administration" Expand="false">
                            <Nodes>
                                <DxTreeViewNode Text="Global Settings" NavigateUrl="globalsettings" />
                                <DxTreeViewNode Text="Company Admin" NavigateUrl="utils/company-admin" />
                                <DxTreeViewNode Text="Projects By Company" NavigateUrl="reporting" />
                                <DxTreeViewNode Text="Download PDF" NavigateUrl="utils/download-pdf" />
                                <DxTreeViewNode Text="Upload Files" NavigateUrl="utils/fileuploader" />
                                <DxTreeViewNode Text="Site Map" NavigateUrl="download-sitemap" />
                            </Nodes>
                        </DxTreeViewNode>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView>
                    <Authorized>
                        <DxTreeViewNode Text="Account" Expand="false">
                            <Nodes>
                                <DxTreeViewNode Text="User Profile" NavigateUrl="Account/Manage" />
                            </Nodes>
                        </DxTreeViewNode>
                    </Authorized>
                    <NotAuthorized>
                        <DxTreeViewNode Text="Account" Expand="false">
                            <Nodes>
                                <DxTreeViewNode Text="Register" NavigateUrl="Account/Register" />
                                <DxTreeViewNode Text="Login" NavigateUrl="Account/Login" />
                            </Nodes>
                        </DxTreeViewNode>
                    </NotAuthorized>
                </AuthorizeView>
            </Nodes>
        </DxTreeView>
    </div>

    <!-- Dark mode toggle -->
    <div class="logout-section">
        <label class="logout-button" style="cursor: pointer;">
            <i class="fa-solid @(ThemeService.IsDarkMode ? "fa-sun" : "fa-moon")"></i>
            <span>@(ThemeService.IsDarkMode ? "Light Mode" : "Dark Mode")</span>
            <input type="checkbox" checked="@ThemeService.IsDarkMode"
                   @onchange="ToggleDarkMode"
                   style="margin-left: auto;" />
        </label>
    </div>

    <!-- Logout section -->
    <div class="logout-section">
        <AuthorizeView>
            <Authorized>
                <form action="@logoutUrl" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                    <button type="submit" class="logout-button">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
[Parameter]
public EventCallback OnNavigated { get; set; }

private string? currentUrl;
private string? logoutUrl;
private string? currentUserId;

protected override void OnInitialized()
{
    logoutUrl = NavigationManager.ToAbsoluteUri("Account/Logout").ToString();
    currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
    NavigationManager.LocationChanged += OnLocationChanged;
}

private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
{
    currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
    await OnNavigated.InvokeAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Sync ThemeService with the server-rendered data-bs-theme attribute
                var currentTheme = await JS.InvokeAsync<string?>("document.documentElement.getAttribute", "data-bs-theme");
                ThemeService.IsDarkMode = currentTheme == "dark";

                // Cache user ID for toggle saves
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;
                if (user.Identity?.IsAuthenticated == true)
                {
                    var appUser = await UserManager.GetUserAsync(user);
                    if (appUser is not null)
                    {
                        currentUserId = appUser.Id;
                    }
                }

                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task ToggleDarkMode()
    {
        ThemeService.IsDarkMode = !ThemeService.IsDarkMode;
        var value = ThemeService.IsDarkMode ? "dark" : "light";
        await JS.InvokeVoidAsync("document.documentElement.setAttribute", "data-bs-theme", value);

        // Persist to database for the authenticated user
        if (currentUserId is not null)
        {
            try
            {
                var appUser = await UserManager.FindByIdAsync(currentUserId);
                if (appUser is not null)
                {
                    appUser.IsDarkMode = ThemeService.IsDarkMode;
                    await UserManager.UpdateAsync(appUser);
                }
            }
            catch { }
        }
    }
}
