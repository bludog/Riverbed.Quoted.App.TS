@page "/reportviewer/"
@page "/reportviewer/{CustomerProjectGuid}"

@using DevExpress.Blazor.Reporting
@using DevExpress.XtraReports.UI
@using Riverbed.Pricing.Paint.Reports.PredefinedReports

<link href="_content/DevExpress.Blazor.Themes/blazing-berry.bs5.css" rel="stylesheet" />
<link href="_content/DevExpress.Blazor.Reporting.Viewer/css/dx-blazor-reporting-components.bs5.css" rel="stylesheet" />

<DxReportViewer @ref="reportViewer" Report="Report" RootCssClasses="w-100 h-100" />

@code {
    DxReportViewer reportViewer;
    XtraReport Report = new CustomerProjectQuoteVI();
    [Parameter] public Guid CustomerProjectGuid { get; set; }

    public override async Task SetParametersAsync(ParameterView parameters)
    {
        ShowReport();
    }

    void ShowReport()
    {
        Report.Parameters["CustomerProjectGuid"].Value = CustomerProjectGuid;
        reportViewer.Report = Report;
    }
}