@page "/"
@using MudBlazor
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<Home> Logger
@rendermode InteractiveWebAssembly

<MudPaper Class="pa-6 d-flex flex-column align-center justify-center" Elevation="0">
    <MudProgressCircular Color="MudBlazor.Color.Primary" Indeterminate="true" Size="MudBlazor.Size.Large" />
    <MudText Typo="Typo.h6" Class="mt-4">Loading dashboard...</MudText>
</MudPaper>

@code {
    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Home.OnInitializedAsync");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
		Logger.BeginScope("Home.OnAfterRenderAsync");
        if (firstRender)
        {
			Logger.LogInformation("Home.OnAfterRenderAsync firstRender");
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (!authState.User.Identity.IsAuthenticated)
            {
				Logger.LogInformation("Home.OnAfterRenderAsync User not authenticated, redirecting to Login");
                NavigationManager.NavigateTo("/login", true);
            }
            else
            {
				Logger.LogInformation("Home.OnAfterRenderAsync User authenticated, redirecting to Quoted Projects");
                NavigationManager.NavigateTo("dashboard");
            }
        }
    }
}
