@page "/login"
@using System.ComponentModel.DataAnnotations
@inject ServerAuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<MudPaper Class="pa-6 mx-auto mt-12" Style="max-width: 420px;">
    <MudText Typo="Typo.h5" GutterBottom="true">Sign in</MudText>

    <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
        <DataAnnotationsValidator />

        <MudTextField Label="Email"
                      Variant="Variant.Outlined"
                      @bind-Value="_model.Email"
                      For="@(() => _model.Email)"
                      Required="true"
                      Class="mb-4" />

        <MudTextField Label="Password"
                      Variant="Variant.Outlined"
                      InputType="InputType.Password"
                      @bind-Value="_model.Password"
                      For="@(() => _model.Password)"
                      Required="true"
                      Class="mb-2" />

        <MudCheckBox T="bool" @bind-Value="_model.RememberMe" Label="Remember me" Class="mb-4" />

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@_errorMessage</MudAlert>
        }

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="_isSubmitting">
            @(_isSubmitting ? "Signing in..." : "Sign in")
        </MudButton>
    </EditForm>
</MudPaper>

@code {
    private readonly LoginModel _model = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    private async Task HandleLoginAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        var response = await AuthenticationStateProvider.LoginAsync(new LoginRequest
        {
            Email = _model.Email,
            Password = _model.Password,
            RememberMe = _model.RememberMe
        });

        _isSubmitting = false;

        if (response.Succeeded)
        {
            Navigation.NavigateTo("/", forceLoad: true);
            return;
        }

        if (response.IsLockedOut)
        {
            _errorMessage = "Your account is locked out.";
            return;
        }

        if (response.RequiresTwoFactor)
        {
            _errorMessage = "Two-factor authentication is required for this account.";
            return;
        }

        _errorMessage = "Invalid login attempt.";
    }

    private sealed class LoginModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}
