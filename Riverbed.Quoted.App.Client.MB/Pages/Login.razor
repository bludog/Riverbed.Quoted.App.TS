@page "/login"
@attribute [AllowAnonymous]
@using System.ComponentModel.DataAnnotations
@inject ServerAuthenticationClient AuthenticationClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Log in</PageTitle>

<MudGrid Justify="Justify.Center" Class="mt-16">
    <MudItem xs="12" sm="10" md="6" lg="4">
        <MudPaper Class="pa-6" Elevation="8">
            <MudText Typo="Typo.h5" Class="mb-4">Sign in</MudText>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined" Class="mb-4">@_errorMessage</MudAlert>
            }

            <EditForm Model="_input" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_input.Email"
                              Label="Email"
                              For="@(() => _input.Email)"
                              InputType="InputType.Email"
                              InputId="login-email"
                              Autocomplete="username"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              Required="true"
                              Class="mb-3" />

                <MudTextField @bind-Value="_input.Password"
                              Label="Password"
                              For="@(() => _input.Password)"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              InputId="login-password"
                              Autocomplete="current-password"
                              Immediate="true"
                              Required="true"
                              Class="mb-2" />

                <MudCheckBox @bind-Value="_input.RememberMe" Label="Remember me" Class="mb-4" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="_isSubmitting">
                    @(_isSubmitting ? "Signing in..." : "Sign in")
                </MudButton>
            </EditForm>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private readonly LoginInputModel _input = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo(GetSafeReturnUrl(), replace: true);
        }
    }

    private async Task SubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var loginResponse = await AuthenticationClient.LoginAsync(new LoginRequest(
                _input.Email,
                _input.Password,
                _input.RememberMe));

            if (loginResponse.Succeeded)
            {
                if (AuthenticationStateProvider is ServerAuthenticationStateProvider serverAuthenticationStateProvider)
                {
                    await serverAuthenticationStateProvider.RefreshAuthenticationStateAsync();
                }

                NavigationManager.NavigateTo(GetSafeReturnUrl(), replace: true);
                return;
            }

            _errorMessage = loginResponse.IsLockedOut
                ? "Your account is locked."
                : loginResponse.RequiresTwoFactor
                    ? "Two-factor authentication is required."
                    : "Invalid login attempt.";
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Unable to sign in at this time.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string GetSafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/";
        }

        if (Uri.TryCreate(ReturnUrl, UriKind.Absolute, out _))
        {
            return "/";
        }

        return ReturnUrl.StartsWith('/') ? ReturnUrl : $"/{ReturnUrl}";
    }

    private sealed class LoginInputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}
