@page "/pricing/projectentrymain/{CustomerId}/{ProjectId}"
@page "/pricing/projectentrymain/{ProjectId}"

@using System.IO
@using System.Runtime.InteropServices.ComTypes
@using System.Reflection.Metadata
@using System.Net
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Http
@using static System.Net.WebRequestMethods
@using Riverbed.Pricing.Paint.Reports.Utils
@using static Riverbed.Pricing.Paint.Client.Pages.Components.EmailEditor.EmailEditorTemplateManger
@using DevExpress.Blazor
@using Riverbed.Pricing.Paint.Shared.Data
@using System.Text.Json

@inject FileSaveHelper FileSaveHelper
@inject ILogger<ProjectEntryMain> Logger
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IPricingService IPricingService
@inject IJSRuntime JSRuntime
@layout NoMenuLayout
@rendermode InteractiveWebAssembly

<style>
    .rb-status-pill .dxbs-editor-input {
        border-radius: 999px;
        padding: 2px 12px;
        font-weight: 600;
    }

    .rb-status-pill {
        min-width: 170px;
    }

</style>

<LoadingIndicator @ref="loadingIndicator" Loaded="StartLoadingIndicator">
    <AuthorizeView>
        <Authorized>
            <Button Color="Color.Link" Clicked="() => NavigationManager.NavigateTo(customerProjectsURL)">
                <Icon Name="IconName.ChevronLeft" IconSize="IconSize.Large" /> Back to @companyCustomer.FirstName @companyCustomer.LastName
            </Button>
            @{
                authorized = true;
            }
        </Authorized>   
         <NotAuthorized>  
             <Row Class="w-100 my-2">
                <Column TextAlignment="TextAlignment.End">
                  <Button Color="Color.Link"
                                Clicked="() => NavigationManager.NavigateTo(loginURL)">
                    Log in
                  </Button>
              </Column>
            </Row>
        </NotAuthorized>
    </AuthorizeView>

    <Layout>
        <LayoutContent>
            <Card>
                <CardBody Background="Background.Light" Style="border-color:none">
                    <AuthorizeView>
                        <Authorized>
                            <Dropdown Flex="Flex.JustifyContent.End.AlignItems.End">
                                <DropdownToggle><Icon Name="IconName.Bars" IconSize="IconSize.Large" /></DropdownToggle>
                                <DropdownMenu>                            
                                    <Dropdown>
                                        <DropdownToggle>Quote</DropdownToggle>
                                        <DropdownMenu>
                                            <DropdownItem Clicked="@(() => ShowEmailPopup())" Disabled="@(rooms.Count <= 0)"><Icon Name="IconName.Mail" IconSize="IconSize.Default" /> Email Quote</DropdownItem>
                                            <DropdownItem Clicked="@(() => GetQuotePdf())" Disabled="@(rooms.Count <= 0)"><Icon Name="IconName.Download" IconSize="IconSize.Default" /> Download Quote</DropdownItem>
                                            <DropdownItem Clicked="@(() => ViewProjectQuote())" Disabled="false"><Icon Name="IconName.FilePdf" IconSize="IconSize.Default" /> View Quote</DropdownItem>
                                        </DropdownMenu>
                                    </Dropdown>
                                    <Dropdown>
                                        <DropdownToggle>Work Order</DropdownToggle>
                                        <DropdownMenu>
                                            <DropdownItem Clicked="@(() => ViewProjectWorkOrder())" Disabled="false"><Icon Name="IconName.FilePdf" IconSize="IconSize.Default" /> View Work Order</DropdownItem>
                                            <DropdownItem Clicked="@ShowWorkOrderPopup" Disabled="false"><Icon Name="IconName.Link" IconSize="IconSize.Default" /> Work Order Link</DropdownItem>
                                        </DropdownMenu>
                                    </Dropdown>                                                    
                                    <DropdownItem Clicked="@(() => DiscountPopupVisible = true)" Disabled="@HideQuoteEdits"><Icon Name="IconName.ChartPie" IconSize="IconSize.Default" /> Discount</DropdownItem>
                                    <DropdownItem Clicked="@(() => GlobalChangesPopupVisible = true)" Disabled="@(rooms.Count <= 0 || selectedProject.StatusCodeId == 2)"><Icon Name="IconName.Edit" IconSize="IconSize.Default" /> Global Room Settings</DropdownItem>
                                    <DropdownItem Clicked="@(() => ProjectActionsVisible = true)">
                                        <Icon Name="IconName.Settings" IconSize="IconSize.Default" /> Project Send/Status/Edit
                                    </DropdownItem>
                                    <DropdownDivider />
                                    <DropdownItem Clicked="@(() => EditProjectModalVisible = true)" Disabled="@HideQuoteEdits"><Icon Name="IconName.Pen" IconSize="IconSize.Default" /> Edit Project</DropdownItem>
                                    <DropdownItem Clicked="@(() => DeletePopupVisible = true)" Disabled="@(!authorized || HideQuoteEdits)"><Icon Name="IconName.Delete" IconSize="IconSize.Default" /> Delete Project</DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                    </Authorized>
                    </AuthorizeView>
                    <Div Class="d-flex justify-content-center align-items-center gap-2">
                        <Div Class="d-flex justify-content-center align-items-center gap-2 flex-wrap">
                            <Div Class="d-flex justify-content-center align-items-center gap-2 flex-wrap">
                                <Heading Size="HeadingSize.Is3" Class="mb-0">@selectedProject.ProjectName</Heading>

                                <Dropdown>
                                    <DropdownToggle>
                                        <Badge Color="Color.Primary" Pill="true" Class="px-3 py-2">
                                            @statusText
                                        </Badge>
                                    </DropdownToggle>

                                    <DropdownMenu>
                                        @if (statusCodes is not null)
                                        {
                                            @foreach (var s in statusCodes)
                                            {
                                                <DropdownItem Disabled="@isSavingInlineStatus"
                                                              Clicked="@(() => SetStatusAsync(s.Id))">
                                                    @s.StatusCodeName
                                                </DropdownItem>
                                            }
                                        }
                                    </DropdownMenu>
                                </Dropdown>

                                @if (isSavingInlineStatus)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                }
                            </Div>
                      

                        @if (isSavingInlineStatus)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        }
                    </Div>
                      
                    </Div>

                    <Div TextAlignment="TextAlignment.Center">
                        <Heading Size="HeadingSize.Is6" TextColor="TextColor.Muted">@selectedProject.Address1, @selectedProject.City, @selectedProject.StateCode @selectedProject.ZipCode</Heading>
                        <Div Class="d-flex flex-column gap-1 align-items-center">
                            @if (!string.IsNullOrWhiteSpace(selectedProject.CustomerEmail) || !string.IsNullOrWhiteSpace(selectedProject.SecondaryCcEmail))
                            {
                                <Div Class="d-flex flex-wrap gap-2 justify-content-center align-items-center">
                                    @if (!string.IsNullOrWhiteSpace(selectedProject.CustomerEmail))
                                    {
                                        <Span class="text-muted">Email:</Span>
                                        <Span class="fw-semibold">@selectedProject.CustomerEmail</Span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(selectedProject.SecondaryCcEmail))
                                    {
                                        <Span class="text-muted">CC:</Span>
                                        <Span class="fw-semibold">@selectedProject.SecondaryCcEmail</Span>
                                    }
                                </Div>
                            }
                            @if (!string.IsNullOrWhiteSpace(selectedProject.CustomerPhone) || !string.IsNullOrWhiteSpace(selectedProject.SecondaryPhoneNumber))
                            {
                                <Div Class="d-flex flex-wrap gap-2 justify-content-center align-items-center">
                                    @if (!string.IsNullOrWhiteSpace(selectedProject.CustomerPhone))
                                    {
                                        <Icon Name="IconName.Phone" IconSize="IconSize.Small" />
                                        <Span class="fw-semibold">@selectedProject.CustomerPhone</Span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(selectedProject.SecondaryPhoneNumber))
                                    {
                                        <Span class="text-muted">Alt:</Span>
                                        <Span class="fw-semibold">@selectedProject.SecondaryPhoneNumber</Span>
                                    }
                                </Div>
                            }
                        </Div>
                        <Heading Size="HeadingSize.Is6">@((MarkupString)selectedProject.Summary)</Heading>
                        <Heading Size="HeadingSize.Is6">@rooms.Count - Rooms</Heading>
                        <AuthorizeView Context="NewContext">
                            <Authorized>
                                <DxButton RenderStyle="ButtonRenderStyle.Primary" RenderStyleMode="ButtonRenderStyleMode.Outline" Click="@(() => ProjectActionsVisible = true)">
                                     Project Send/Status/Edit
                                </DxButton>

                            </Authorized>
						</AuthorizeView>        
                       
                    </Div>
                </CardBody>
            </Card>
            <br />

            <DxPopup @bind-Visible="@EditProjectModalVisible" 
                     HeaderText="Edit Project" 
                     ShowFooter="false" 
                     Width="800px" 
                     MaxWidth="95vw" 
                     MinHeight="400px"
                     MaxHeight="95vh"
                     CloseOnOutsideClick="false"
                     Scrollable="true"
                     SizeMode="SizeMode.Large">
                <BodyContentTemplate Context="popupContext">
                    <Div Style="max-height: calc(95vh - 100px); overflow-y: auto; padding: 1rem;">
                        <EditForm EditContext="@editContext" OnValidSubmit="SaveProjectModal" OnInvalidSubmit="HandleInvalidProjectSubmit">
                        <ChildContent Context="formContext">
                            <DataAnnotationsValidator />
                            <Microsoft.AspNetCore.Components.Forms.ValidationSummary />
                            <DxFormLayout>
                                <DxFormLayoutItem Caption="Project Name" ColSpanMd="12">
                                    <DxTextBox @bind-Text="@selectedProject.ProjectName" ShowValidationIcon="true" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Email" ColSpanMd="12">
                                    <DxTextBox NullText="Email Address" ShowValidationIcon="true" @bind-Text="@selectedProject.CustomerEmail" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Phone Number" ColSpanMd="12">
                                    <DxTextBox NullText="123-456-7890" Mask="000-000-0000" @bind-Text="@selectedProject.CustomerPhone" ShowValidationIcon="true" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="CC Email" ColSpanMd="12">
                                    <DxTextBox NullText="CC Email Address" ShowValidationIcon="true" @bind-Text="@selectedProject.SecondaryCcEmail" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Alternate Phone" ColSpanMd="12">
                                    <DxTextBox NullText="123-456-7890" Mask="000-000-0000" @bind-Text="@selectedProject.SecondaryPhoneNumber" ShowValidationIcon="true" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Summary" ColSpanMd="12">
                                    <DxMemo @bind-Text="@selectedProject.Summary" ShowValidationIcon="true" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Address" ColSpanMd="12">
                                    <GoogleAddressAutocomplete OnAddressSelected="@HandleAddressSelected" SearchText="@GetFullAddress()"/>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Show Address" ColSpanMd="12">
                                    <DxCheckBox @bind-Checked="@showAddressFields">
                                        Show Address    
                                    </DxCheckBox>
                                </DxFormLayoutItem>
                                <DxFormLayoutGroup Caption="Address Details" Visible="@showAddressFields">
                                    <DxFormLayoutItem Caption="Address Line 1" ColSpanLg="12" ColSpanMd="12" ColSpanSm="12" BeginRow="true">
                                        <DxTextBox NullText="Address Line 1" @bind-Text="@selectedProject.Address1" ShowValidationIcon="true" />
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Address Line 2" ColSpanLg="12" ColSpanMd="12" ColSpanSm="12" BeginRow="true">
                                        <DxTextBox NullText="Address Line 2" @bind-Text="@selectedProject.Address2" ShowValidationIcon="true" />
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="City" ColSpanLg="6" ColSpanMd="6" ColSpanSm="12" BeginRow="true">
                                        <DxTextBox NullText="City Name" @bind-Text="@selectedProject.City" ShowValidationIcon="true" />
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="State" ColSpanLg="6" ColSpanMd="6" ColSpanSm="12">
                                        <DxTextBox NullText="State Code" @bind-Text="@selectedProject.StateCode" ShowValidationIcon="true" />
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Zip" ColSpanLg="6" ColSpanMd="6" ColSpanSm="12" BeginRow="true">
                                        <DxTextBox NullText="Zip Code" Mask="00000" @bind-Text="@selectedProject.ZipCode" ShowValidationIcon="true" />
                                    </DxFormLayoutItem>
                                </DxFormLayoutGroup>
                                <DxFormLayoutItem Caption="Copy Another Project" ColSpanMd="12">
                                    <DxCheckBox @bind-Checked="@copyAnotherProjectSelected">
                                        Copy Another Project (@allCustomers.Count customers available)
                                    </DxCheckBox>
                                </DxFormLayoutItem>
                                @if (copyAnotherProjectSelected)
                                {
                                    <DxFormLayoutGroup Caption="Copy Project" Visible="@copyAnotherProjectSelected">
                                        <DxFormLayoutItem Caption="Select Customer:" ColSpanMd="12">
                                            <DxComboBox Data="@allCustomers"
                                                        TextFieldName="FirstName"
                                                        ValueFieldName="Id"
                                                        @bind-Value="@selectedCopyCustomerId"
                                                        NullText="Select Customer">
                                                <ItemTemplate Context="customer">
                                                    @customer.FirstName @customer.LastName
                                                </ItemTemplate>
                                            </DxComboBox>
                                        </DxFormLayoutItem>
                                        @if (selectedCopyCustomerId != 0 && customerProjectsDict.ContainsKey(selectedCopyCustomerId))
                                        {
                                            <DxFormLayoutItem Caption="Select Project:" ColSpanMd="12">
                                                <DxComboBox Data="@customerProjectsDict[selectedCopyCustomerId]"
                                                            TextFieldName="ProjectName"
                                                            ValueFieldName="ProjectGuid"
                                                            @bind-Value="@selectedCopyProjectGuid"
                                                            NullText="Select Project">
                                                    <ItemTemplate Context="project">
                                                        @project.ProjectName
                                                    </ItemTemplate>
                                                </DxComboBox>
                                            </DxFormLayoutItem>
                                        }
                                    </DxFormLayoutGroup>
                                }
                                <DxFormLayoutItem>
                                    <DxButton SubmitFormOnClick="true" Text="Submit" />
                                    <DxButton RenderStyle="ButtonRenderStyle.Secondary" Click="@HideProjectModal" Text="Cancel" />
                                </DxFormLayoutItem>
                            </DxFormLayout>
                        </ChildContent>
                    </EditForm>
                    </Div>
                </BodyContentTemplate>
            </DxPopup>

            <CardDeck>
                <Card Shadow="Shadow.Default" Border="Border.Rounded">
                    <ListGroup Flush Mode="ListGroupMode.Selectable" @bind-SelectedItem="@selectedItem" >
                        <ListGroupItem Name="rooms" Flex="Flex.JustifyContent.End.AlignItems.End">
                            <Button Color="Color.Link" Clicked="HandleNewHouseArea" hidden="@HideQuoteEdits">Add House</Button>
                            <Button Color="Color.Link" Clicked="HandleNewArea" hidden="@HideQuoteEdits">Add Room</Button>
                            <Button Color="Color.Link" Clicked="HandleNewExteriorArea" hidden="@HideQuoteEdits">Add Exterior</Button>
                        </ListGroupItem>
                        <Repeater Items="@rooms" Context="room">
                            <ListGroupItem Name="@room.Id.ToString()">
                                <Div Flex="Flex.JustifyContent.Between.AlignItems.Center">
                                    <Div Class="d-flex align-items-center gap-2">
                                        @if (room.RoomImageId.HasValue)
                                        {
                                            <img src="@GetRoomThumbnailUrl(room.RoomImageId.Value)" 
                                                 alt="@room.Name" 
                                                 class="room-thumbnail" 
                                                 style="width: 60px; height: 60px; object-fit: cover; border-radius: 4px; border: 1px solid #dee2e6;" />
                                        }
                                        <Div>
                                            <Heading Size="HeadingSize.Is5" Margin="Margin.Is1.FromBottom">
                                                <Badge Color="Color.Success" Pill>@GetRoomNum()</Badge> @room.Name
                                                @{
                                                    if (room.IsOptional)
                                                    {
                                                        <text> (Optional)</text>
                                                    }
                                                }
                                            </Heading>
                                        </Div>
                                    </Div>
                                    <Text TextWeight="TextWeight.Bold">@room.TotalCost().ToString("C")</Text>
                                </Div>

                                <Div Flex="Flex.JustifyContent.Between.AlignItems.Center">
                                    <Paragraph Margin="Margin.Is1.FromBottom">
                                        @{
                                            if (room.IncludeWalls || room.IncludeDoors || room.IncludeCeilings || room.IncludeBaseboards || room.IncludeWindows)
                                            {
                                                <Div><Blazorise.Text TextSize="TextSize.Small">@GetRoomMeasurements(room)</Blazorise.Text></Div>
                                            }                                            
                                        }
                                        <Div><Text TextSize="TextSize.Small">@GetRoomOptions(room)</Text></Div>
                                        <Div>
                                            @foreach(var item in room.PaintableItems)
                                            {
                                                <Blazorise.Text TextSize="TextSize.Small" TextWeight="TextWeight.SemiBold" Display="Display.Block">
                                                    @item.Count - @item.Name
                                                </Blazorise.Text>
                                            }
                                        </Div> 
                                       <Div>
                                            @if (room.Notes != null)
                                            {
                                                    notesVisible = Visibility.Visible;
                                            }
                                                <Text TextSize="TextSize.Small" TextWeight="TextWeight.SemiBold" Visibility="@notesVisible">@room.Notes</Text>
                                        </Div>
                                    </Paragraph>
                                    <Button Color="Color.Link" Clicked="@(() => {selectedRoom = room; OnItemClicked();})" hidden="@HideQuoteEdits">
                                        <Icon Name="IconName.ChevronRight" IconSize="IconSize.Large" />
                                    </Button> 
                                </Div>

                                <Div Flex="Flex.JustifyContent.Between.AlignItems.Center">
                                    <Div Class="d-flex gap-2">
                                        <Button Size="Size.Small" Color="Color.Link"
                                        Clicked="@(() => {selectedRoom = room; ShowImageUploadPopup = true;})" hidden="@HideQuoteEdits">
                                            <Icon Name="IconName.Image" /> Image
                                        </Button>
                                        <Button Size="Size.Small" Color="Color.Link"
                                        Clicked="@(() => {selectedRoom = room; DeleteRoomPopupVisible = true;})" hidden="@HideQuoteEdits">
                                            Delete
                                        </Button>
                                    </Div>
                                </Div>
                            </ListGroupItem>
                        </Repeater>
                        <ListGroupItem Name="total" Flex="Flex.JustifyContent.End.AlignItems.End">
                            <Div>                                                                    
                                <Div>
                                    <Heading Size="HeadingSize.Is5">Project Total: @GetProjectTotal()</Heading>
                                </Div>
                                @if (GetDiscountAmountDecimal() > 0)
                                {
                                    <Div>
                                        <Heading Size="HeadingSize.Is5">Discount (@GetProjectDiscount()): @GetDiscountAmount()</Heading>
                                    </Div>                                
                                    <Div>
                                        <Heading Size="HeadingSize.Is5">Adjusted Price: @selectedProject.BaseAmount.ToString("C")</Heading>
                                    </Div>
                                }
                            </Div>
                        </ListGroupItem>
                    </ListGroup>
                </Card>
            </CardDeck>
        </LayoutContent>
    </Layout>
</LoadingIndicator>

<DxPopup @bind-Visible="@ReportPopupVisible"
ShowFooter="true"
HeaderText="Delete Project">
    <BodyContentTemplate>
         <ReportViewer CustomerProjectId="@ProjectId"></ReportViewer>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Secondary" Text="Cancel" Click="@(() => ReportPopupVisible = false)" />
    </FooterContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="@DiscountPopupVisible"
ShowFooter="true"
HeaderText="Project Discount">
    <BodyContentTemplate>
        <Fields>
            <Field>
                <FieldLabel for="Discount Amount" RequiredIndicator>Discount (%)</FieldLabel>
                <NumericEdit id="Discount" @bind-Value="@discountAdjustment.Value" Placeholder="Discount %" />
            </Field>            
        </Fields>

    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Primary" Text="OK" Click="@(() => SaveDiscountModal())" />
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Secondary" Text="Cancel" Click="@(() => DiscountPopupVisible = false)" />
    </FooterContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="@DeletePopupVisible"
ShowFooter="true"
HeaderText="Delete Project">
    <BodyContentTemplate>
        Are you sure you want to delete this project?
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Primary" Text="OK" Click="@(async () => { await DeleteProjectModal(); })" />
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Secondary" Text="Cancel" Click="@(() => DeletePopupVisible = false)" />
    </FooterContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="@DeleteRoomPopupVisible"
ShowFooter="true"
HeaderText="Delete Room">
    <BodyContentTemplate>
        Are you sure you want to delete this Room?
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Primary" Text="OK" Click="@(() => DeleteRoomModal())" />
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Secondary" Text="Cancel" Click="@(() => DeleteRoomPopupVisible = false)" />
    </FooterContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="@ShowImageUploadPopup"
ShowFooter="true"
HeaderText="@($"Room Image - {selectedRoom?.Name}")"
Width="500px">
    <BodyContentTemplate>
        @if (selectedRoom != null)
        {
            <RoomImageUpload RoomId="@selectedRoom.Id" OnImageChanged="@HandleImageChanged" />
        }
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Secondary" Text="Close" Click="@(() => ShowImageUploadPopup = false)" />
    </FooterContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="@QuotePopupVisible"
ShowFooter="true"
HeaderText="Project Quote"
Width="1000px"
MaxWidth="95vw"
MaxHeight="90vh"
SizeMode="SizeMode.Large">
    <BodyContentTemplate>
        <iframe src="@quoteViewerUrl" style="width:100%; height:80vh; border:none;"></iframe>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Primary" Text="Download" Click="@(() => DownloadProjectQuote())" />
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Secondary" Text="Close" Click="@(() => QuotePopupVisible = false)" />
    </FooterContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="@WorkOrderPopupVisible"
    ShowFooter="true"
    HeaderText="Work Order Link">
    <BodyContentTemplate>
        <Fields>
            <Field>
                <FieldLabel for="WorkOrderLink">Link</FieldLabel>
                <DxTextBox id="WorkOrderLink" Text="@workOrderUrl" ReadOnly="true" />
            </Field>
        </Fields>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Primary" Text="Copy Link" Click="@CopyWorkOrderLink" />
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Secondary" Text="Close" Click="@(() => WorkOrderPopupVisible = false)" />
    </FooterContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="@GlobalChangesPopupVisible"
    ShowFooter="true"
    HeaderText="Global Room Settings"
    Width="700px" MaxWidth="95vw">
    <BodyContentTemplate>
        <Div Class="d-flex flex-column gap-3">
            <Div>
                <label class="form-label">Walls</label>
                <DxComboBox TData="string" TValue="string" Data="@triStateOptions" @bind-Value="includeWallsSelection" />
            </Div>
            <Div>
                <label class="form-label">Ceilings</label>
                <DxComboBox TData="string" TValue="string" Data="@triStateOptions" @bind-Value="includeCeilingsSelection" />
            </Div>
            <Div>
                <label class="form-label">Doors</label>
                <DxComboBox TData="string" TValue="string" Data="@triStateOptions" @bind-Value="includeDoorsSelection" />
            </Div>
            <Div>
                <label class="form-label">Windows</label>
                <DxComboBox TData="string" TValue="string" Data="@triStateOptions" @bind-Value="includeWindowsSelection" />
            </Div>
            <Div>
                <label class="form-label">Baseboards</label>
                <DxComboBox TData="string" TValue="string" Data="@triStateOptions" @bind-Value="includeBaseboardsSelection" />
            </Div>
            <Div>
                <label class="form-label">Crown Molding</label>
                <DxComboBox TData="string" TValue="string" Data="@triStateOptions" @bind-Value="includeCrownMoldingSelection" />
            </Div>
            <Div>
                <DxCheckBox @bind-Checked="changePaintQuality">Change Paint Quality for all rooms</DxCheckBox>
            </Div>
            @if (changePaintQuality)
            {
                <Div>
                    <label class="form-label">Paint Quality</label>
                    <DxComboBox TData="PaintQuality" TValue="int" Data="@paintQualities" TextFieldName="PaintQualityName" ValueFieldName="Id" @bind-Value="selectedPaintQualityId" NullText="Select Paint Quality" />
                </Div>
            }
            <Div Class="text-muted" Style="font-size: 0.9rem;">
                Note: Only selections set to Include or Exclude will be applied. Unchanged leaves existing room settings.
            </Div>
        </Div>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Primary" Text="Apply" Click="@ApplyGlobalRoomSettingsAsync" />
        <DxButton CssClass="popup-button my-1 ms-2" RenderStyle="ButtonRenderStyle.Secondary" Text="Cancel" Click="@(() => GlobalChangesPopupVisible = false)" />
    </FooterContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="ProjectActionsVisible"
         HeaderText="Project Actions"
         ShowFooter="false"
         Width="90vw"
         MaxWidth="90vw"
         Height="90vh"
         MaxHeight="90vh"
         Scrollable="true">
    <BodyContentTemplate>
        <ProjectOptionsPanel ProjectGuid="@selectedProject.ProjectGuid"
                             StatusChanged="OnStatusChangedFromPanel"
                             ProjectChanged="OnProjectChangedFromPanel" />
    </BodyContentTemplate>
</DxPopup>


<Snackbar @ref="snackbarPrimary" Color="SnackbarColor.Primary" Location="SnackbarLocation.Bottom">
    <SnackbarBody>@snackbarPrimaryMessage</SnackbarBody>
</Snackbar>


