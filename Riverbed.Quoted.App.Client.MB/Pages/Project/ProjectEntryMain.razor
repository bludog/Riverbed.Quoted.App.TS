    public async Task SaveProjectModal()
    {
        // var isValid = validations.ValidateAll();
        bool isValid = true; // Assume validation passes for simplicity
        if (isValid)
        {
            // Capture the copy state before resetting
            bool wasCopyingProject = copyAnotherProjectSelected;
            Guid copyFromProjectGuid = selectedCopyProjectGuid;
            
            await SaveProject();
            EditProjectModalVisible = false;
            copyAnotherProjectSelected = false;
            StateHasChanged();

            if (selectedProject.Id == 0)
            {
                snackbarPrimaryMessage = "Unable to save project. Please try again."; 
                await snackbarPrimary.Show();
                return;
            }

            var roomCount = rooms?.Count ?? 0;
            Console.WriteLine($"Project Area Count: {roomCount}");
            
            // If we copied from another project, the rooms should already be copied by DuplicateCustomerProjectAsync
            // We just need to reload the rooms and stay on this page
            if (wasCopyingProject && copyFromProjectGuid != Guid.Empty)
            {
                Console.WriteLine("Project was copied. Reloading rooms.");
                rooms = await pricingService.GetRoomsByProjectIdAsync(selectedProject.Id) ?? new List<Room>();
                snackbarPrimaryMessage = $"Copied {rooms.Count} rooms from the selected project.";
                await snackbarPrimary.Show();
                StateHasChanged();
            }
            // If we have a project with no areas and didn't copy, go to the house wizard
            else if (roomCount == 0)
            {
                Console.WriteLine("Navigating to the House Wizard.");
                NavigationManager.NavigateTo("pricing/project-house-wizard/" + ProjectId);
            }
        }
        else
        {
            snackbarPrimaryMessage = "Unable to save project. Please try again.";
            snackbarPrimary.Show();
        }

        return;
    }

