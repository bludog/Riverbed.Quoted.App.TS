    public async Task SaveProject()
    {
        if (selectedProject.Id == 0)
        {
            try
            {
                selectedProject.CompanyCustomerGuidId = Guid.Parse(CustomerId);

                // Normalize optional fields to prevent validation errors on empty strings
                selectedProject.NormalizeOptionalFields();

                // If we are copying another project then also pass the other project Guid on creation
                if (copyAnotherProjectSelected)
                    selectedProject = await pricingService.DuplicateCustomerProjectAsync(selectedCopyProjectGuid.ToString(), selectedProject);
                else
                    selectedProject = await pricingService.CreateCustomerProjectAsync(selectedProject);

                ProjectId = selectedProject.ProjectGuid.ToString();           
                snackbarPrimaryMessage = $"Successfully Created Project {selectedProject.ProjectName}.";
                await snackbarPrimary.Show();
                //SendProjectNotification("New Painting Project", EmailType.CustomerLinkToQuote);                
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Error creating project: {Message}", ex.Message);
                snackbarPrimaryMessage = $"Failed to create project. Please try again. {ex.Message}";
                await snackbarPrimary.Show();
            }
        }
        else
        {
            // Normalize optional fields to prevent validation errors on empty strings
            selectedProject.NormalizeOptionalFields();

            await pricingService.UpdateCustomerProjectAsync(selectedProject);
            snackbarPrimaryMessage = $"Updated Project {selectedProject.ProjectName}.";
            await snackbarPrimary.Show();
        }

        statusText = statusCodes.Find(x => x.Id == selectedProject.StatusCodeId).StatusCodeName;
        StateHasChanged();
    }

    public async Task SaveDiscount()
