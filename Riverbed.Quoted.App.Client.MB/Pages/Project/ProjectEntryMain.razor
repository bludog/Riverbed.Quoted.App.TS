    public string GetRoomOptions(Room room)
    {
        string options = "";
        options = GetRoomOptionText("Walls", room.IncludeWalls);
        options += GetRoomOptionText("Windows", room.IncludeWindows, options.Length > 0);
        options += GetRoomOptionText("Doors", room.IncludeDoors, options.Length > 0);
        options += GetRoomOptionText("Ceilings", room.IncludeCeilings, options.Length > 0);
        options += GetRoomOptionText("Baseboards", room.IncludeBaseboards, options.Length > 0);
        options += GetRoomOptionText("Crown Molding", room.IncludeCrownMoldings, options.Length > 0);
        return options;
    }

    // Pass in a string with an Include boolean with another boolean if there should be a forward slash appended to the front of the string
    public string GetRoomOptionText(string options, bool include, bool appendForwardSlash = false)
    {
        if (include)
            options = appendForwardSlash ? $"/{options}" : $"{options}";
        else
            options = "";
        return options;
    }

