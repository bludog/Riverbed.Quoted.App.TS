    public async Task LoadData()
    {
        Logger.LogInformation("[LoadData] Start: ProjectId={ProjectId}, CustomerId={CustomerId}", ProjectId, CustomerId);

        try
        {
            // For new projects (ProjectId == "0"), we need CustomerId to be provided
            if (string.IsNullOrEmpty(CustomerId))
            {
                // Only try to get CustomerId from existing project if ProjectId is not "0"
                if (ProjectId != "0")
                {
                    var project = await pricingService.GetCustomerProjectAsync(ProjectId);
                    if (project == null)
                    {
                        Logger.LogWarning("[LoadData] No project found for ProjectId={ProjectId}", ProjectId);
                        return;
                    }
                    CustomerId = project.CompanyCustomerGuidId.ToString();
                    Logger.LogInformation("[LoadData] CustomerId set from project: {CustomerId}", CustomerId);
                }
                else
                {
                    // ProjectId is "0" but CustomerId is empty - cannot proceed
                    Logger.LogWarning("[LoadData] Cannot create new project without CustomerId");
                    return;
                }
            }

            companyCustomer = await pricingService.GetCompanyCustomerAsync(CustomerId);
            if (companyCustomer == null)
            {
                Logger.LogWarning("[LoadData] No company customer found for CustomerId={CustomerId}", CustomerId);
                return;
            }
            Logger.LogInformation("[LoadData] Loaded companyCustomer: {companyCustomer}", JsonSerializer.Serialize(companyCustomer));

            var custId = companyCustomer.Id;
            customerProjectsURL = "company-customer-display/" + CustomerId;

            if (ProjectId == "0")
            {
                discountAdjustment = new Adjustment(selectedProject.Id, AdjustmentType.Discount, 0);
                selectedProject = new ProjectData()
            {
                CompanyCustomerId = custId,
                ProjectGuid = Guid.NewGuid(),
                Id = 0,
                CreatedDate = DateTime.Now,
                BaseAmount = 0,
                CompletedDate = DateTime.Now.AddDays(30),
                StatusCodeId = 1,
                CustomerEmail = string.Empty,
                CustomerPhone = string.Empty,
                ProjectName = string.Empty,
                Address1 = string.Empty,
                Address2 = string.Empty,
                City = string.Empty,
                StateCode = string.Empty,
                ZipCode = string.Empty,
                Adjustments = new List<Adjustment> { new Adjustment(selectedProject.Id, AdjustmentType.Discount, 0) },
                Summary = "Painting Project",
                ScopeOfWork = "",
                ServiceTitanId = 0
            };

                if (authorized && companyCustomer != null && selectedProject != null)
                {
                    selectedProject.Address1 = companyCustomer.Address1;
                    selectedProject.Address2 = companyCustomer.Address2;
                    selectedProject.City = companyCustomer.City;
                    selectedProject.StateCode = companyCustomer.StateCode;
                    selectedProject.ZipCode = companyCustomer.ZipCode;
                    selectedProject.CustomerEmail = companyCustomer.Email;
                    selectedProject.CustomerPhone = companyCustomer.MobilePhone ?? string.Empty;
                    selectedProject.SecondaryCcEmail = companyCustomer.SecondaryCcEmail;
                    selectedProject.SecondaryPhoneNumber = companyCustomer.SecondaryPhoneNumber;
                }
                Logger.LogInformation("[LoadData] Created new project: {selectedProject}", JsonSerializer.Serialize(selectedProject));
            }
            else
            {
                selectedProject = await pricingService.GetCustomerProjectAsync(ProjectId);
                if (selectedProject == null)
                {
                    Logger.LogWarning("[LoadData] No project found for ProjectId={ProjectId}", ProjectId);
                    return;
                }
                Logger.LogInformation("[LoadData] Loaded selectedProject: {selectedProject}", JsonSerializer.Serialize(selectedProject));

                rooms = await pricingService.GetRoomsByProjectIdAsync(selectedProject.Id) ?? new List<Room>();
                Logger.LogInformation("[LoadData] Loaded {RoomCount} rooms: {Rooms}", rooms.Count, JsonSerializer.Serialize(rooms));

                // Recalculate projectTotal from actual room data to ensure BaseAmount stays in sync
                projectTotal = 0;
                foreach (var room in rooms)
                {
                    if (room != null && !room.IsOptional)
                        projectTotal += room.TotalCost();
                }

                if (selectedProject.Adjustments.Count == 0)
                {
                    discountAdjustment = new Adjustment(selectedProject.Id, AdjustmentType.Discount, 0);
                    selectedProject.Adjustments.Add(discountAdjustment);
                }
                else
                {
                    discountAdjustment = selectedProject.Adjustments.Find(x => x.Type == AdjustmentType.Discount);
                }

                // Always persist the fresh total (including discount) so CompanyCustomerDisplay is accurate
                await GetProjectTotalWithDiscount();
            }

            statusCodes = await pricingService.GetAllStatusCodesAsync() ?? new List<StatusCode>();
            paintQualities = await pricingService.GetAllPaintQualitiesAsync() ?? new List<PaintQuality>();
            Logger.LogInformation("[LoadData] Loaded {StatusCodeCount} status codes, {PaintQualityCount} paint qualities", statusCodes.Count, paintQualities.Count);

            if (companyCustomer != null)
            {
                company = await pricingService.GetCompanyAsync(companyCustomer.CompanyId);
                Logger.LogInformation("[LoadData] Loaded company: {company}", JsonSerializer.Serialize(company));
            }

            HideQuoteEdits = selectedProject != null && selectedProject.StatusCodeId >= 2 && selectedProject.StatusCodeId != 8;
            if (selectedProject != null && statusCodes != null)
            {
                var st = statusCodes.Find(x => x.Id == selectedProject.StatusCodeId);
                statusText = st != null ? st.StatusCodeName : string.Empty;
                inlineStatusId = selectedProject.StatusCodeId;

                await InitInlineStatusAsync();
            }
            else
            {
                statusText = string.Empty;
            }

            Logger.LogInformation("[LoadData] End: ProjectName={ProjectName}, StatusText={StatusText}, Rooms={RoomCount}, HideQuoteEdits={HideQuoteEdits}",
                selectedProject?.ProjectName, statusText, rooms?.Count, HideQuoteEdits);

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[LoadData] Exception occurred: {Message}", ex.Message);
            throw;
        }
    }

    public string GetProjectTotal()
    {
        // build project total
        projectTotal = 0;
        if(rooms.Count != 0)
        {
            foreach (var room in rooms)
            {
                if(room == null)
                    continue;

                if (!room.IsOptional)
                    projectTotal += room.TotalCost();
            }
        }

        return projectTotal.ToString("C");
    }

    public string GetDiscountAmount()
    {
        decimal discount = GetDiscountAmountDecimal();
        return discount.ToString("C");
    }

    public decimal GetDiscountAmountDecimal()
    {
        decimal discount = 0;
        if (discountAdjustment != null)
        {
            if (discountAdjustment.IsPercentage)
            {
                discount = (decimal)(projectTotal * ((float)discountAdjustment.Value / 100));
            }
            else
            {
                discount = discountAdjustment.Value;
            }
        }
        return discount;
    }

    public async Task GetProjectTotalWithDiscount()
    {
        var discount = GetDiscountAmountDecimal();
        discountTotal = Math.Round((decimal)projectTotal - discount, 2);

        // Add a margin of error of ±1
        var withinMarginOfError = (selectedProject.BaseAmount <= discountTotal + 1 && selectedProject.BaseAmount >= discountTotal - 1);

        // Update Project with new Total BaseAmount
        if (selectedProject != null && !withinMarginOfError )
        {
            // Save the project with the new total
            await pricingService.UpdateProjectBaseAmountAsync(selectedProject.Id, discountTotal);
            selectedProject.BaseAmount = discountTotal;            
        }   
        //_adjustedPrice = discountTotal.ToString("C");
    }

    public string GetProjectDiscount()
    {
        var discount = selectedProject.Adjustments.Find(x => x.Type == AdjustmentType.Discount);

        if (discount == null)
            return "0";

        return discount.IsPercentage ? $"{discount.Value}%" : discount.Value.ToString("C");
    }

