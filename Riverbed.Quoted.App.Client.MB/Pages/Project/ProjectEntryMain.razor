    private string GetFullAddress()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(selectedProject.Address1))
            parts.Add(selectedProject.Address1);
        if (!string.IsNullOrWhiteSpace(selectedProject.City))
            parts.Add(selectedProject.City);
        if (!string.IsNullOrWhiteSpace(selectedProject.StateCode))
            parts.Add(selectedProject.StateCode);
        if (!string.IsNullOrWhiteSpace(selectedProject.ZipCode))
            parts.Add(selectedProject.ZipCode);
        return string.Join(", ", parts);
    }

    private Task OnStatusChangedFromPanel(int newStatusId)
    {
        // keep the inline dropdown in sync immediately
        inlineStatusId = newStatusId;

        // if you want panel save to ONLY update UI (and panel already saved DB),
        // use ApplyStatusUI(newStatusId). If you want belt+suspenders, call SaveStatusAsync.
        return ApplyStatusUIAsync(newStatusId);
    }

    private Task OnProjectChangedFromPanel(ProjectData updated)
    {
        selectedProject = updated;

        inlineStatusId = selectedProject.StatusCodeId;
        statusText = statusCodes?.FirstOrDefault(x => x.Id == selectedProject.StatusCodeId)?.StatusCodeName ?? statusText;

        HideQuoteEdits = selectedProject.StatusCodeId >= 2 && selectedProject.StatusCodeId != 8;

        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task ApplyStatusUIAsync(int newStatusId)
    {
        if (selectedProject is null) return Task.CompletedTask;

        selectedProject.StatusCodeId = newStatusId;
        statusText = statusCodes?.FirstOrDefault(x => x.Id == newStatusId)?.StatusCodeName ?? statusText;

        HideQuoteEdits = selectedProject.StatusCodeId >= 2 && selectedProject.StatusCodeId != 8;

        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task SetStatusAsync(int newStatusId)
    {
        if (selectedProject is null || isSavingInlineStatus) return;

        // Prevent duplicate saves
        if (newStatusId == selectedProject.StatusCodeId) return;

        isSavingInlineStatus = true;
        StateHasChanged();

        try
        {
            var previousStatusId = selectedProject.StatusCodeId;

            // Update the project status
            selectedProject.StatusCodeId = newStatusId;

            // Normalize optional fields to prevent validation errors on empty strings
            selectedProject.NormalizeOptionalFields();

            await pricingService.UpdateCustomerProjectAsync(selectedProject);

            // Update UI
            inlineStatusId = newStatusId;
            statusText = statusCodes?.FirstOrDefault(x => x.Id == newStatusId)?.StatusCodeName ?? statusText;
            HideQuoteEdits = selectedProject.StatusCodeId >= 2 && selectedProject.StatusCodeId != 8;

            snackbarPrimaryMessage = "Project status updated successfully.";
            await snackbarPrimary.Show();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update project status");
            snackbarPrimaryMessage = "Failed to update project status. Please try again.";
            await snackbarPrimary.Show();

            // Revert UI on error
            selectedProject.StatusCodeId = inlineStatusId;
            statusText = statusCodes?.FirstOrDefault(x => x.Id == inlineStatusId)?.StatusCodeName ?? statusText;
        }
        finally
        {
            isSavingInlineStatus = false;
            StateHasChanged();
        }
    }

