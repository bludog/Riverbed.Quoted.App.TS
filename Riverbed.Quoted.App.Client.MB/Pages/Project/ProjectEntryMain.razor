    private bool? ParseSelection(string selection)
    {
        return selection switch
        {
            "Include" => true,
            "Exclude" => false,
            _ => (bool?)null
        };
    }

    private async Task ApplyGlobalRoomSettingsAsync()
    {
        try
        {
            if (selectedProject.StatusCodeId == 2)
            {
                snackbarPrimaryMessage = "Project is accepted. Global changes are not allowed.";
                await snackbarPrimary.Show();
                return;
            }

            var request = new RoomInclusionsRequest
            {
                IncludeWalls = ParseSelection(includeWallsSelection),
                IncludeCeilings = ParseSelection(includeCeilingsSelection),
                IncludeDoors = ParseSelection(includeDoorsSelection),
                IncludeWindows = ParseSelection(includeWindowsSelection),
                IncludeBaseboards = ParseSelection(includeBaseboardsSelection),
                IncludeCrownMoldings = ParseSelection(includeCrownMoldingSelection)
            };

            var updatedCount = await pricingService.UpdateRoomInclusionsAsync(selectedProject.Id, request);

            int paintUpdatedCount = 0;
            if (changePaintQuality && selectedPaintQualityId > 0)
            {
                try
                {
                    paintUpdatedCount = await pricingService.UpdateRoomPaintQualityAsync(selectedProject.Id, selectedPaintQualityId);
                }
                catch (Exception ex)
                {
                    snackbarPrimaryMessage = $"Failed to update paint quality: {ex.Message}";
                    await snackbarPrimary.Show();
                }
            }

            GlobalChangesPopupVisible = false;
            StateHasChanged();

            await loadingIndicator.Show();

            await pricingService.PriceHouseInteriorAsync(selectedProject.Id);

            rooms = await pricingService.GetRoomsByProjectIdAsync(selectedProject.Id);

            // Recalculate project total from the repriced rooms
            projectTotal = 0;
            foreach (var room in rooms)
            {
                if (room != null && !room.IsOptional)
                    projectTotal += room.TotalCost();
            }

            // Update the persisted BaseAmount (accounts for any active discount)
            await GetProjectTotalWithDiscount();

            if (paintUpdatedCount > 0)
                snackbarPrimaryMessage = $"Applied global settings to {updatedCount} rooms, updated paint quality for {paintUpdatedCount} rooms and recalculated totals.";
            else
                snackbarPrimaryMessage = $"Applied global settings to {updatedCount} rooms and recalculated totals.";
            await snackbarPrimary.Show();
        }
        catch (Exception ex)
        {
            snackbarPrimaryMessage = $"Failed to apply global settings: {ex.Message}";
            await snackbarPrimary.Show();
        }
        finally
        {
            await loadingIndicator.Hide();
        }
    }

