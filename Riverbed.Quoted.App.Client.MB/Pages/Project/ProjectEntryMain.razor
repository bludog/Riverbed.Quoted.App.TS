        if (emailType == EmailType.CustomerLinkToQuote && selectedProject.StatusCodeId == 2)
            quoteLink = $"https://bludog-software.com/rbp/reports/project-quote-report-main/{ProjectId}";

        var quoteLinkShortened = $"{selectedProject.ProjectName}-Quote";
        var body = BuildEmailBody(quoteLink, quoteLinkShortened, contactNumber, contactEmail, emailType, selectedProject.ProjectName);

        // send
        await pricingService.SendEmailAsync(
            toEmailAddress, subject, body, "Painting Quote",
            company.Email, contactEmail, true,
            selectedProject.ProjectGuid.ToString(), company.Id.ToString()
        );

        // ✅ business rule: New -> Proposed after sending proposal
        if (selectedProject.StatusCodeId == 1 && emailType == EmailType.CustomerLinkToQuote)
        {
            selectedProject.StatusCodeId = 8; // Proposed
            selectedProject.NormalizeOptionalFields();
            await pricingService.UpdateCustomerProjectAsync(selectedProject);

            statusText = statusCodes?.FirstOrDefault(x => x.Id == 8)?.StatusCodeName ?? statusText;
            HideQuoteEdits = selectedProject.StatusCodeId >= 2 && selectedProject.StatusCodeId != 8;
        }

        snackbarPrimaryMessage = $"Email Sent to {toEmailAddress}.";
        await snackbarPrimary.Show();
    }


    private string BuildEmailBody(string quoteLink, string quoteLinkShortened, string contactNumber, string contactEmail, EmailType emailType, string custName = "Customer")
    {
        var emailTemplateManager = new EmailEditorTemplateManger();
        var template = emailTemplateManager.GetEmailTemplateById(emailType);
        string companySignature = GetCompanySignature();

        var templateBody = template.Body + companySignature;
        var body = string.Format(templateBody, custName, company.CompanyName, quoteLink, quoteLinkShortened, contactNumber, contactEmail);

        return body;
    }

