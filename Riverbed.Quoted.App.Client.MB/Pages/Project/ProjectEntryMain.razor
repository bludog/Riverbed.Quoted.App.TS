    // Copy all the CompanyHTMLReportTemplates to the CompanyHTMLReports table and set the ProjectId to the current project id
    public async Task CopyCompanyHTMLReportsTemplateToProject()
    {
        if (string.IsNullOrEmpty(ProjectId) || ProjectId == "0")
        {
            snackbarPrimaryMessage = "Project ID is not set. Cannot copy reports.";
            await snackbarPrimary.Show();
            return;
        }
        var reports = await pricingService.GetCompanyHTMLReportTemplatesByCompanyAsync(company.Id.ToString());
        foreach (var report in reports)
        {
            // Check if the report already exists for the project
            var existingReport = await pricingService.GetCompanyHTMLReportByTypeAndProjectAsync(report.ReportTypeId, ProjectId);
            if (existingReport != null)
            {
                snackbarPrimaryMessage = $"Report of type {report.ReportTypeId} already exists for this project. Skipping copy.";
                continue; // Skip copying if the report already exists
            }

            // Create a new report for the project
            var newReport = new CompanyHTMLReport
            {
                CompanyGuid = report.CompanyGuid,
                CompanyName = report.CompanyName,
                ReportHTMLText = report.ReportHTMLText,
                ReportTypeId = report.ReportTypeId,
                IsGlobalTemplate = false,
                LastUpdatedDateTime = DateTime.Now,
                IsActive = true,
                DisplayOrder = report.DisplayOrder,
                ProjectGuid = Guid.Parse(ProjectId) // Set the ProjectId to the current project
            };
            await pricingService.CreateCompanyHTMLReportAsync(newReport);
        }
        snackbarPrimaryMessage = "Copied Company HTML Reports Template to Project.";
        await snackbarPrimary.Show();
    }

