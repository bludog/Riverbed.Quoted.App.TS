    /// <summary>
    /// Sends a notification email to the company when a project is accepted.
    /// </summary>
    private async Task SendCompanyAcceptanceNotificationAsync()
    {
        if (company is null || string.IsNullOrWhiteSpace(company.Email))
            return;

        var customerName = $"{companyCustomer?.FirstName} {companyCustomer?.LastName}".Trim();
        var quoteLink = $"https://bludog-software.com/rbp/reports/project-quote-report-main/{ProjectId}";

        var body = $@"
            <p>Project <strong>{selectedProject.ProjectName}</strong> has been accepted by {customerName}.</p>
            <p>Customer Email: {selectedProject.CustomerEmail}</p>
            <p>Customer Phone: {selectedProject.CustomerPhone}</p>
            <p>Address: {selectedProject.Address1}, {selectedProject.City}, {selectedProject.StateCode} {selectedProject.ZipCode}</p>
            <p>View quote: <a href='{quoteLink}'>{selectedProject.ProjectName} Quote</a></p>";

        try
        {
            await pricingService.SendProjectEmailAsync(
                selectedProject.ProjectGuid.ToString(),
                $"Project Accepted - {selectedProject.ProjectName}",
                body,
                toAddress: company.Email,
                senderName: "Quoted Notification",
                senderEmail: company.Email);

            snackbarPrimaryMessage = $"Company notification sent to {company.Email}.";
            await snackbarPrimary.Show();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to send company acceptance notification");
            snackbarPrimaryMessage = $"Project accepted but company notification failed: {ex.Message}";
            await snackbarPrimary.Show();
        }
    }

