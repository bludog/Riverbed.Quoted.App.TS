    protected override async Task OnAfterRenderAsync(bool firstRender)
    {    
        if (firstRender)
        {
            if (loadingIndicator != null)
            {
                await loadingIndicator.Show();
            }

            this.firstRender = false;
            await LoadData();

            // Log navigation to a project at Information level
            try
            {
                Logger.LogInformation("Navigated to Project {ProjectId}", ProjectId);
            }
            catch { }

            // Rebind the EditContext to the selectedProject after loading data
            editContext = new EditContext(selectedProject);
            
            if (loadingIndicator != null)
            {
                await loadingIndicator.Hide();
            }
            
            // Only fetch customers once when the copy project option should be shown
            if (string.IsNullOrEmpty(ProjectId) || ProjectId == "0")
            {
                previousShowCopyProjectMenu = true;
                copyAnotherProjectSelected = false;
                EditProjectModalVisible = true;
                
                if (allCustomers.Count == 0 && companyCustomer?.CompanyId != null)
                {
                    isLoadingCopyMenu = true;
                    StateHasChanged();
                    allCustomers = await pricingService.GetAllCompanyCustomersByGuidAsync(companyCustomer.CompanyId.ToString());
                    isLoadingCopyMenu = false;
                    snackbarPrimaryMessage = $"Found {allCustomers.Count} customers.";
                    await snackbarPrimary.Show();
                }
            }
            
            StateHasChanged();            
            
        }

        // Only fetch customers when checkbox is checked AND customers haven't been loaded yet
        if (previousShowCopyProjectMenu != copyAnotherProjectSelected && copyAnotherProjectSelected && allCustomers.Count == 0)
        {
            previousShowCopyProjectMenu = copyAnotherProjectSelected;
            customerProjectsDict.Clear();
            selectedCopyCustomerId = 0;
            selectedCopyProjectGuid = Guid.Empty;
            isLoadingCopyMenu = true;
            StateHasChanged();
            allCustomers = await pricingService.GetAllCompanyCustomersByGuidAsync(companyCustomer.CompanyId.ToString());
            isLoadingCopyMenu = false;
            snackbarPrimaryMessage = $"Found {allCustomers.Count} customers.";
            await snackbarPrimary.Show();
            StateHasChanged();
        }
        else if (previousShowCopyProjectMenu != copyAnotherProjectSelected)
        {
            previousShowCopyProjectMenu = copyAnotherProjectSelected;
        }

        // Only fetch projects when customer is selected
        if (previousSelectedCopyCustomerId != selectedCopyCustomerId && selectedCopyCustomerId != 0)
        {
            previousSelectedCopyCustomerId = selectedCopyCustomerId;
            customerProjectsDict.Remove(selectedCopyCustomerId); // Clear previous projects for this customer
            var projects = await pricingService.GetAllCustomerProjectsAsync(selectedCopyCustomerId);
            customerProjectsDict[selectedCopyCustomerId] = projects;
            StateHasChanged();
        }
        else
        {
            previousSelectedCopyCustomerId = selectedCopyCustomerId;
        }
    }

    private async Task InitInlineStatusAsync()
    {
        if (selectedProject is null) return;
        inlineStatusId = selectedProject.StatusCodeId;
    }

    private async Task SetStatusAsync(int newStatusId, string source = "inline")
    {
        if (selectedProject is null) return;
        if (newStatusId == selectedProject.StatusCodeId) return;

        try
        {
            isSavingInlineStatus = true;

            selectedProject.StatusCodeId = newStatusId;
            await IPricingService.UpdateCustomerProjectAsync(selectedProject);

            // update UI state immediately
            inlineStatusId = newStatusId;
            statusText = statusCodes?.FirstOrDefault(x => x.Id == newStatusId)?.StatusCodeName ?? "";

            HideQuoteEdits = selectedProject.StatusCodeId >= 2 && selectedProject.StatusCodeId != 8;

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Status update failed ({Source})", source);

            // revert dropdown
            inlineStatusId = selectedProject.StatusCodeId;
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            isSavingInlineStatus = false;
            await InvokeAsync(StateHasChanged);
        }
    }



