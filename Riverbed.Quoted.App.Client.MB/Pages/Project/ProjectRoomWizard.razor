    // Modal
    // ----------------------------
    private void ShowModal() => ShowPopup = true;
    private void HideModal() => ShowPopup = false;

    // ----------------------------
    // Logging wrapper
    // ----------------------------
    private async Task LogAndExecute(string actionName, Func<Task> action)
    {
        try
        {
            Logger.LogInformation("[{ActionName}] Button clicked. Current Step: {SelectedStep}, ProjectId: {ProjectId}, AreaId: {AreaId}",
                actionName, selectedStep, ProjectId, AreaId);

            if (action != null)
                await action.Invoke();

            Logger.LogInformation("[{ActionName}] Action completed successfully.", actionName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[{ActionName}] An error occurred: {Message}", actionName, ex.Message);
        }
    }
