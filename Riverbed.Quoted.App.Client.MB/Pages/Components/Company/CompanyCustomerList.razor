@page "/company-customer-list"
@using MudBlazor

@inject ILogger<CompanyCustomerList> Logger
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IPricingService IPricingService
@rendermode InteractiveWebAssembly
@attribute [Authorize]

<style>
    .customer-meta-text {
        color: #9aa0a6 !important;
    }
</style>

<MudPaper Class="pa-4" Elevation="1">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="MudBlazor.AlignItems.Center" Class="mb-3" Wrap="Wrap.Wrap">
        <MudText Typo="Typo.h5">Customer List</MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="MudBlazor.Variant.Outlined" Href="/project/quoted-projects" StartIcon="@Icons.Material.Filled.Folder">Project List</MudButton>
            <MudButton Variant="MudBlazor.Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="HandleNew" StartIcon="@Icons.Material.Filled.Add">New</MudButton>
        </MudStack>
    </MudStack>

    <MudTextField T="string" @bind-Value="searchTerm" Placeholder="Search by first or last name..." Variant="MudBlazor.Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="mb-4" />

    @if (isLoading)
    {
        <MudStack AlignItems="MudBlazor.AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" Color="MudBlazor.Color.Primary" />
        </MudStack>
    }
    else if (filteredCompanyCustomerList.Any())
    {
        <MudList T="CompanyCustomer" Dense="true">
            @foreach (var customer in filteredCompanyCustomerList)
            {
                <MudListItem T="CompanyCustomer" Class="mb-2">
                    <MudPaper Class="pa-3 w-100" Elevation="0" Outlined="true">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="MudBlazor.AlignItems.Start">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle1">@customer.LastName, @customer.FirstName</MudText>
                                <MudText Typo="Typo.caption" Class="customer-meta-text">@customer.City, @customer.StateCode @customer.ZipCode</MudText>
                                <MudText Typo="Typo.caption" Class="customer-meta-text">Created: @(customer.CreatedDate?.ToString("MMM d, yyyy") ?? "-")</MudText>
                            </MudStack>

                            <MudStack Row="true" Spacing="1">
                                <MudButton Variant="MudBlazor.Variant.Text" Color="MudBlazor.Color.Primary" OnClick="@(() => OnItemClicked(customer.CustomerId.ToString()))">View</MudButton>
                                <MudButton Variant="MudBlazor.Variant.Text" Color="MudBlazor.Color.Error" OnClick="@(() => ConfirmDelete(customer))">Delete</MudButton>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudListItem>
            }
        </MudList>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="MudBlazor.Variant.Outlined">No customers found.</MudAlert>
    }
</MudPaper>

@if (showDeleteDialog && customerToDelete is not null)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="2000" AutoClose="false">
        <MudPaper Class="pa-4" Style="width: 420px; max-width: 90vw; margin: 20vh auto 0 auto;">
            <MudText Typo="Typo.h6" Class="mb-2">Confirm Delete</MudText>
            <MudText Typo="Typo.body2" Class="mb-4">Are you sure you want to delete @customerToDelete.FirstName @customerToDelete.LastName?</MudText>
            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                <MudButton Variant="MudBlazor.Variant.Text" OnClick="CancelDelete">Cancel</MudButton>
                <MudButton Variant="MudBlazor.Variant.Filled" Color="MudBlazor.Color.Error" OnClick="DeleteCustomerAsync">Delete</MudButton>
            </MudStack>
        </MudPaper>
    </MudOverlay>
}

@code {
    public string _companyGuid { get; set; }
    public IEnumerable<CompanyCustomer> companyCustomerList { get; set; } = new List<CompanyCustomer>();
    public CompanyCustomer companyCustomer { get; set; }
    public int customerId { get; set; } = 0;
    public IPricingService pricingService { get; set; }
    private bool isLoading;
    private bool showDeleteDialog;
    private CompanyCustomer? customerToDelete;

    private string searchTerm = string.Empty;

    private IEnumerable<CompanyCustomer> filteredCompanyCustomerList =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? companyCustomerList
            : companyCustomerList.Where(c =>
                (!string.IsNullOrEmpty(c.FirstName) && c.FirstName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrEmpty(c.LastName) && c.LastName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            );

    protected override async Task OnInitializedAsync()
    {
        pricingService = IPricingService;
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (!(authState.User?.Identity?.IsAuthenticated ?? false))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadData();
    }

    public async Task OnItemClicked(string item)
    {
        NavigationManager.NavigateTo("company-customer-display/" + item);
    }

    public void HandleNew()
    {
        NavigationManager.NavigateTo("company-customer-edit/" + customerId);
    }

    public async Task LoadData()
    {
        try
        {
            isLoading = true;
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userName = user?.Identity?.Name;
            
            Logger.LogInformation("LoadData: Starting customer list load for user: {UserName}", userName);
            
            if (string.IsNullOrWhiteSpace(userName))
            {
                Logger.LogWarning("LoadData: Username is empty or null");
                companyCustomerList = Array.Empty<CompanyCustomer>();
                StateHasChanged();
                return;
            }
            
            _companyGuid = await pricingService.GetUserCompanyGuidAsync(userName);
            Logger.LogInformation("LoadData: Retrieved company guid: {CompanyGuid}", _companyGuid);
            
            if (string.IsNullOrWhiteSpace(_companyGuid))
            {
                Logger.LogWarning("LoadData: Company guid is empty or null for user: {UserName}", userName);
                companyCustomerList = Array.Empty<CompanyCustomer>();
                StateHasChanged();
                return;
            }
            
            companyCustomerList = await pricingService.GetAllCompanyCustomersByGuidAsync(_companyGuid);
            Logger.LogInformation("LoadData: Retrieved {Count} customers for company: {CompanyGuid}", companyCustomerList?.Count() ?? 0, _companyGuid);
            
            companyCustomer = companyCustomerList.FirstOrDefault();
            if (companyCustomer == null)
            {
                Logger.LogWarning("LoadData: No customers found in the list");
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "LoadData: Error loading customer data");
            companyCustomerList = Array.Empty<CompanyCustomer>();
            StateHasChanged();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ConfirmDelete(CompanyCustomer customer)
    {
        customerToDelete = customer;
        showDeleteDialog = true;
    }

    private void CancelDelete()
    {
        showDeleteDialog = false;
        customerToDelete = null;
    }

    private async Task DeleteCustomerAsync()
    {
        if (customerToDelete is not null)
        {
            isLoading = true;
            await pricingService.DeleteCompanyCustomerAsync(customerToDelete.Id);
            await LoadData();
            CancelDelete();
        }
    }
}