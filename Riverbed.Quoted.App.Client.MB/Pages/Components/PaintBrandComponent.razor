@page "/paintbrand"
@inject HttpClient Http
@inject ILogger<PaintBrandComponent> Logger
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IPricingService IPricingService
@rendermode InteractiveWebAssembly


<LoadingIndicator @bind-Visible="@isBusy">
<DxGrid Data="@PaintBrands"
EditModelSaving="@Grid_EditModelSaving"
        DataItemDeleting="@Grid_DataItemDeleting"
        EditMode="GridEditMode.PopupEditForm"
        @ref="MyGrid">
    <Columns>
        <DxGridDataColumn FieldName="PaintBrandName" Caption="Brand" />
        <DxGridCommandColumn Width="60px">
            <HeaderTemplate>
                <DxButton Click="() => MyGrid.StartEditNewRowAsync()" Text="New" RenderStyle="ButtonRenderStyle.Success" SizeMode="SizeMode.Small" />
            </HeaderTemplate>
            <CellDisplayTemplate>
                @{
                        <Blazicon Svg="Ionicon.Pencil" Style="margin-right: 10px;" @onclick="() => MyGrid.StartEditDataItemAsync(context.DataItem)" />
                        <Blazicon Svg="Ionicon.TrashBin" Style="margin-right: 10px;" @onclick="() => MyGrid.ShowDataItemDeleteConfirmation(context.DataItem)" />
                    }
            </CellDisplayTemplate>
        </DxGridCommandColumn>
    </Columns>
    <EditFormTemplate Context="EditFormContext">
        @{
            var newPaintBrand = (PaintBrand)EditFormContext.EditModel;
        }
        <DxFormLayout>
            <DxFormLayoutItem Caption="Paint Brand Name">
                <DxTextBox @bind-Text="@newPaintBrand.PaintBrandName" />
            </DxFormLayoutItem>
        </DxFormLayout>
    </EditFormTemplate>
    </DxGrid>
</LoadingIndicator>

@code {
public PaintBrand paintBrand { get; set; } = new PaintBrand();
    public bool isBusy { get; set; } = false;
    public List<PaintBrand> PaintBrands { get; set; }
    private IPricingService pricingService;
    public IGrid MyGrid { get; set; }

    protected override async Task OnInitializedAsync()
    {
        pricingService = IPricingService;
        await UpdateDataAsync();
    }

    async Task Grid_EditModelSaving(GridEditModelSavingEventArgs e)
    {
        var newPaintBrand = (PaintBrand)e.EditModel;
        if (newPaintBrand.Id == 0)
        {
            await pricingService.CreatePaintBrandAsync(newPaintBrand);
        }
        else
        {
            await pricingService.UpdatePaintBrandAsync(newPaintBrand);
        }
        await UpdateDataAsync();
    }

async Task Grid_DataItemDeleting(GridDataItemDeletingEventArgs e)
    {
        await pricingService.DeletePaintBrandAsync(((PaintBrand)e.DataItem).Id);
        await UpdateDataAsync();
    }

async Task UpdateDataAsync()
    {
        isBusy = true;
        PaintBrands = await pricingService.GetAllPaintBrandsAsync();
        isBusy = false;
    }

}
