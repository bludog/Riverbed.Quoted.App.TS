@page "/dashboard"

@using MudBlazor
@using Riverbed.Pricing.Paint.Shared.Data

@attribute [Authorize]
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JSRuntime
@inject ILogger<Dashboard> Logger
@inject IPricingService AppService
@rendermode InteractiveWebAssembly

<style>
    .dashboard-muted {
        color: var(--mud-palette-text-secondary) !important;
    }

    .mud-theme-dark .dashboard-muted {
        color: #e8ebf5 !important;
    }
</style>

<PageTitle>@companyName Dashboard</PageTitle>

@if (isLoading)
{
    <MudPaper Class="pa-6 d-flex justify-center">
        <MudProgressCircular Color="MudBlazor.Color.Primary" Indeterminate="true" />
    </MudPaper>
}
else if (isLoaded)
{
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudGrid AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h4">@companyName</MudText>
                <MudText Typo="Typo.subtitle1" Class="dashboard-muted">Dashboard</MudText>
            </MudItem>
            <MudItem xs="12" md="6" Class="d-flex gap-2 justify-end flex-wrap">
                <MudButton Variant="MudBlazor.Variant.Outlined" StartIcon="@Icons.Material.Filled.Public" OnClick="OpenProjectTracker">Project Tracker</MudButton>
                <MudButton Variant="MudBlazor.Variant.Outlined" StartIcon="@Icons.Material.Filled.Person" Href="/company-customer-list">Customer List</MudButton>
                <MudButton Variant="MudBlazor.Variant.Outlined" StartIcon="@Icons.Material.Filled.Folder" Href="/project/quoted-projects">Project List</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudText Typo="Typo.h5" Class="mb-3">Year to Date (@DateTime.Now.Year)</MudText>
    <MudGrid Class="mb-4">
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudText Typo="Typo.h3" Color="MudBlazor.Color.Info">@completedJobsYear</MudText>
                <MudText Typo="Typo.subtitle2" Class="dashboard-muted">Completed Jobs</MudText>
                <MudText Typo="Typo.h6" Color="MudBlazor.Color.Info">@completedJobsTotalYear.ToString("C")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudText Typo="Typo.h3" Color="MudBlazor.Color.Success">@wonQuotesYear</MudText>
                <MudText Typo="Typo.subtitle2" Class="dashboard-muted">Won Quotes</MudText>
                <MudText Typo="Typo.h6" Color="MudBlazor.Color.Success">@wonQuotesTotalYear.ToString("C")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudText Typo="Typo.h3" Color="MudBlazor.Color.Primary">@activeQuotesYear</MudText>
                <MudText Typo="Typo.subtitle2" Class="dashboard-muted">Active Quotes</MudText>
                <MudText Typo="Typo.h6" Color="MudBlazor.Color.Primary">@activeQuotesTotalYear.ToString("C")</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5" Class="mb-3">This Month (@DateTime.Now.ToString("MMMM yyyy"))</MudText>
    <MudGrid Class="mb-4">
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudText Typo="Typo.h3" Color="MudBlazor.Color.Success">@wonQuotesMonth</MudText>
                <MudText Typo="Typo.subtitle2" Class="dashboard-muted">Won Quotes</MudText>
                <MudText Typo="Typo.h6" Color="MudBlazor.Color.Success">@wonQuotesTotalMonth.ToString("C")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudText Typo="Typo.h3" Color="MudBlazor.Color.Primary">@activeQuotesMonth</MudText>
                <MudText Typo="Typo.subtitle2" Class="dashboard-muted">Active Quotes</MudText>
                <MudText Typo="Typo.h6" Color="MudBlazor.Color.Primary">@activeQuotesTotalMonth.ToString("C")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudText Typo="Typo.h3" Color="MudBlazor.Color.Info">@completedJobsMonth</MudText>
                <MudText Typo="Typo.subtitle2" Class="dashboard-muted">Completed Jobs</MudText>
                <MudText Typo="Typo.h6" Color="MudBlazor.Color.Info">@completedJobsTotalMonth.ToString("C")</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <MudItem xs="12" md="6" Class="mb-4">
            <MudPaper Elevation="1" Class="h-100">
                <MudText Typo="Typo.h6" Class="pa-3" Color="MudBlazor.Color.Success">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="me-1" />Won Projects
                </MudText>
                <MudDivider />
                <MudList T="ProjectDataMinimal" Dense="true" Style="max-height: 400px; overflow-y: auto;">
                    @if (wonProjects.Any())
                    {
                        @foreach (var project in wonProjects)
                        {
                            <MudListItem T="ProjectDataMinimal" Class="cursor-pointer" OnClick="@(() => NavigateToProject(project.ProjectGuid))">
                                <MudText Typo="Typo.subtitle2">@project.ProjectName</MudText>
                                <MudText Typo="Typo.caption" Class="dashboard-muted">@project.CustomerName</MudText>
                                <MudText Typo="Typo.caption" Class="dashboard-muted">@project.CreatedDate.ToString("MMM d, yyyy")</MudText>
                            </MudListItem>
                        }
                    }
                    else
                    {
                        <MudListItem T="ProjectDataMinimal">
                            <MudText Typo="Typo.body2" Class="dashboard-muted">No won projects in the last 2 months</MudText>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6" Class="mb-4">
            <MudPaper Elevation="1" Class="h-100">
                <MudText Typo="Typo.h6" Class="pa-3" Color="MudBlazor.Color.Primary">
                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="me-1" />Pending Projects (Last 2 Months)
                </MudText>
                <MudDivider />
                <MudList T="ProjectDataMinimal" Dense="true" Style="max-height: 400px; overflow-y: auto;">
                    @if (pendingProjects.Any())
                    {
                        @foreach (var project in pendingProjects)
                        {
                            <MudListItem T="ProjectDataMinimal" Class="cursor-pointer" OnClick="@(() => NavigateToProject(project.ProjectGuid))">
                                <MudText Typo="Typo.subtitle2">@project.ProjectName</MudText>
                                <MudText Typo="Typo.caption" Class="dashboard-muted">@project.CustomerName</MudText>
                                <MudText Typo="Typo.caption" Class="dashboard-muted">@project.CreatedDate.ToString("MMM d, yyyy")</MudText>
                            </MudListItem>
                        }
                    }
                    else
                    {
                        <MudListItem T="ProjectDataMinimal">
                            <MudText Typo="Typo.body2" Class="dashboard-muted">No pending projects in the last 2 months</MudText>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private bool isLoading = true;
    private bool isLoaded = false;
    private string companyName = string.Empty;
    private string companyGuid = string.Empty;

    // Year statistics
    private int wonQuotesYear = 0;
    private decimal wonQuotesTotalYear = 0;
    private int activeQuotesYear = 0;
    private decimal activeQuotesTotalYear = 0;
    private int completedJobsYear = 0;
    private decimal completedJobsTotalYear = 0;

    // Month statistics
    private int wonQuotesMonth = 0;
    private decimal wonQuotesTotalMonth = 0;
    private int activeQuotesMonth = 0;
    private decimal activeQuotesTotalMonth = 0;
    private int completedJobsMonth = 0;
    private decimal completedJobsTotalMonth = 0;

    // Project lists
    private List<ProjectDataMinimal> wonProjects = new();
    private List<ProjectDataMinimal> pendingProjects = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        if (!authState.User.Identity?.IsAuthenticated ?? true)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        try
        {
            await LoadDashboardData();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDashboardData()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user?.Identity?.IsAuthenticated != true)
            {
                Logger.LogWarning("User not authenticated");
                NavigationManager.NavigateTo("/login");
                return;
            }

            var userEmail = user.Identity.Name;
            companyGuid = await AppService.GetUserCompanyGuidAsync(userEmail ?? "");

            if (string.IsNullOrEmpty(companyGuid))
            {
                Logger.LogWarning("No company found for user {Email}", userEmail);
                return;
            }

            // Load dashboard data from server
            var dashboardData = await AppService.GetDashboardDataAsync(companyGuid);

            // Map data to component fields
            companyName = dashboardData.CompanyName;

            // Year statistics
            wonQuotesYear = dashboardData.WonQuotesYear;
            wonQuotesTotalYear = dashboardData.WonQuotesTotalYear;
            activeQuotesYear = dashboardData.ActiveQuotesYear;
            activeQuotesTotalYear = dashboardData.ActiveQuotesTotalYear;
            completedJobsYear = dashboardData.CompletedJobsYear;
            completedJobsTotalYear = dashboardData.CompletedJobsTotalYear;

            // Month statistics
            wonQuotesMonth = dashboardData.WonQuotesMonth;
            wonQuotesTotalMonth = dashboardData.WonQuotesTotalMonth;
            activeQuotesMonth = dashboardData.ActiveQuotesMonth;
            activeQuotesTotalMonth = dashboardData.ActiveQuotesTotalMonth;
            completedJobsMonth = dashboardData.CompletedJobsMonth;
            completedJobsTotalMonth = dashboardData.CompletedJobsTotalMonth;

            // Project lists
            wonProjects = dashboardData.WonProjects;
            pendingProjects = dashboardData.PendingProjects;

            isLoaded = true;
            Logger.LogInformation("Dashboard loaded for company {CompanyName}", companyName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dashboard data");
        }
    }

    private void NavigateToProject(Guid projectGuid)
    {
        NavigationManager.NavigateTo($"pricing/projectentrymain/{projectGuid}");
    }

    private async Task OpenProjectTracker()
    {
        await JSRuntime.InvokeVoidAsync("window.open", $"https://bludog-software.com/rbt/projects/{companyGuid}", "_blank");
    }
}