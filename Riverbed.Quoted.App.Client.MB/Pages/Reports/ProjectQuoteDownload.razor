@page "/quote-download/{ProjectId:guid}"
@using Riverbed.Pricing.Paint.Shared.Entities
@using Riverbed.Pricing.Paint.Shared.Data
@using System.Net.Http
@using Riverbed.Pricing.Paint.Reports.Utils
@namespace Riverbed.Pricing.Paint.Client.Pages.Reports
@inject IPricingService PricingService
@inject FileSaveHelper FileSaveHelper
@inject NavigationManager NavigationManager
@rendermode InteractiveWebAssembly

<div class="m-4 p-4 border rounded">
    <h3>Project Quote PDF</h3>
    
    @if (isLoading)
    {
        <div class="mt-4">
            <p>Generating PDF...</p>
            <div class="progress">
                <div class="progress-bar progress-bar-striped progress-bar-animated" 
                     role="progressbar" style="width: 100%"></div>
            </div>
        </div>
    }
    else
    {
        <div class="mt-4">
            <button class="btn btn-primary me-2" @onclick="DownloadQuote">
                <i class="fas fa-download"></i> Download Quote
            </button>
            <button class="btn btn-secondary" @onclick="NavigateToViewer">
                <i class="fas fa-eye"></i> View Quote
            </button>
        </div>
    }
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3">
            @errorMessage
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid ProjectId { get; set; }
    
    private bool isLoading = false;
    private string errorMessage = "";
    private ProjectData projectData;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Get basic project info for filename
            projectData = await PricingService.GetCustomerProjectAsync(ProjectId.ToString());
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load project: {ex.Message}";
        }
    }

    private async Task DownloadQuote()
    {
        isLoading = true;
        errorMessage = "";
        
        try
        {
            var pdfBytes = await PricingService.GetInteriorQuoteAsPDFAsync(ProjectId.ToString());

            var fileName = projectData != null 
                ? $"Quote_{projectData.ProjectName.Replace(" ", "_")}_{DateTime.Now:yyyyMMdd}.pdf" 
                : $"ProjectQuote-{ProjectId}.pdf";
            
            var mimeType = "application/pdf";

            await FileSaveHelper.SaveFileAsync(fileName, pdfBytes, mimeType);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to generate PDF: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToViewer()
    {
        NavigationManager.NavigateTo($"reports/project-quote-report-main/{ProjectId}");
    }
}