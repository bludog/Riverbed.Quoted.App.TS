@page "/logout"
@attribute [AllowAnonymous]
@inject ServerAuthenticationClient AuthenticationClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ILogger<Logout> Logger

<PageTitle>Logging out</PageTitle>

<MudGrid Justify="Justify.Center" Class="mt-16">
    <MudItem xs="12" sm="10" md="6" lg="4">
        <MudPaper Class="pa-6" Elevation="4">
            <MudText Typo="Typo.h6" Class="mb-2">Signing out...</MudText>
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AuthenticationClient.LogoutAsync();
        }
        catch (HttpRequestException ex)
        {
            Logger.LogWarning(ex, "Server logout request failed. Proceeding with local authentication state refresh.");
        }

        if (AuthenticationStateProvider is ServerAuthenticationStateProvider serverAuthenticationStateProvider)
        {
            await serverAuthenticationStateProvider.RefreshAuthenticationStateAsync();
        }

        NavigationManager.NavigateTo("/login", replace: true);
    }
}
