@page "/logout"
@inject ServerAuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Logout</PageTitle>

<MudPaper Class="pa-6 mx-auto mt-12" Style="max-width: 420px;">
    <MudText Typo="Typo.h6" GutterBottom="true">Signing out...</MudText>
</MudPaper>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthenticationStateProvider.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
