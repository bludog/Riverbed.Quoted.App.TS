@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <MudText Typo="Typo.body2" Class="d-inline mr-2">Hello, @context.User.Identity?.Name!</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="BeginLogOut">Log out</MudButton>
    </Authorized>
    <NotAuthorized>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="BeginLogIn">Log in</MudButton>
    </NotAuthorized>
</AuthorizeView>

@code{
    public void BeginLogIn()
    {
        Navigation.NavigateTo("/login");
    }

    public void BeginLogOut()
    {
        Navigation.NavigateTo("/logout");
    }
}
